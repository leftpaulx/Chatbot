# =============================================================================
# OB Chatbot — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Snowflake connection
# ---------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_PROJECT_USER=SVC_CHATBOT
PRIVATE_USER_KEY=              # base64-encoded PEM private key (no newlines)

# ---------------------------------------------------------------------------
# Authentication
# Static API key — the widget sends this as Authorization: Bearer <API_KEY>.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ---------------------------------------------------------------------------
API_KEY=

# ---------------------------------------------------------------------------
# Cortex Agent Object
# Tools, model, and instructions are configured on the agent object itself.
# ---------------------------------------------------------------------------
AGENT_PATH=/api/v2/databases/OB_AI/schemas/CHATBOT/agents/PROFITABILITY_AGENT:run
AGENT_TIMEOUT_SEC=300

# ---------------------------------------------------------------------------
# Security
# ALLOWED_ORIGINS: comma-separated list of origins. Use "*" ONLY for local dev.
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=https://portal.yourdomain.com
RATE_LIMIT_RPM=30
MAX_CONCURRENCY=8

# ---------------------------------------------------------------------------
# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT: text (human-readable, good for dev) | json (machine-parseable)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
